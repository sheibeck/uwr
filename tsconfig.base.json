{
  "compilerOptions": {
    "target": "ES2022",
  "module": "ES2022",
  "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
    "@shared/*": ["packages/shared-schema/dist/*.js"],
  "@shared/narrative": ["packages/shared-schema/dist/narrative.d.ts"],
  "@shared/accounts": ["packages/shared-schema/dist/accounts.d.ts"],
  "@shared": ["packages/shared-schema/dist/index.d.ts", "packages/shared-schema/dist/index.js"],
  "@schema/*": ["packages/shared-schema/src/schema/*"],
    "@spacetime/*": ["packages/spacetime-modules/src/*"],
  "@orchestrator/*": ["services/orchestrator/src/*"],
    "@prompt/*": ["packages/prompt-schema/src/*"],
    "@ai/*": ["packages/ai-client/src/*"],
    "@ai/index": ["packages/ai-client/dist/index.d.ts"],
    "spacetimedb": ["types/spacetimedb.d.ts"]
    }
  },
  "exclude": [
    "services/orchestrator/src/module_bindings"  
  ]
}
