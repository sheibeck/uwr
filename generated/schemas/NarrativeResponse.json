{
  "$ref": "#/definitions/NarrativeResponse",
  "definitions": {
    "NarrativeResponse": {
      "type": "object",
      "properties": {
        "narration": {
          "type": "string",
          "maxLength": 1200
        },
        "diegeticMessages": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 300
          },
          "maxItems": 5
        },
        "resolution": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "MOVE",
                "LOOK",
                "TALK",
                "ATTACK",
                "LOOT",
                "CAST_RITUAL",
                "CRAFT",
                "EMOTE"
              ]
            },
            "success": {
              "type": "boolean"
            },
            "summary": {
              "type": "string",
              "maxLength": 200
            },
            "effects": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "STAT_CHANGE",
                      "ITEM_GAIN",
                      "ITEM_LOSS",
                      "MOB_SPAWN",
                      "NPC_STATE",
                      "WORLD_EVENT"
                    ]
                  },
                  "detail": {
                    "type": "string",
                    "maxLength": 240
                  }
                },
                "required": [
                  "type",
                  "detail"
                ],
                "additionalProperties": false
              },
              "maxItems": 15
            }
          },
          "required": [
            "action",
            "success",
            "summary",
            "effects"
          ],
          "additionalProperties": false
        },
        "loreRefsUsed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 20
        },
        "safetyFlags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CONTENT_FILTERED",
              "POTENTIAL_CANON_CONFLICT",
              "NEEDS_HUMAN_REVIEW"
            ]
          },
          "maxItems": 5
        }
      },
      "required": [
        "narration",
        "diegeticMessages",
        "resolution",
        "loreRefsUsed",
        "safetyFlags"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}